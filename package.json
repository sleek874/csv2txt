{
  "name": "csv2txt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Privacy-first browser conversion from CSV and Excel to fixed-width Big5 text with a default 15-column profile.",
  "scripts": {
    "dev": "vite",
    "check": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "build": "npm run check && vite build",
    "generate:testdata": "node scripts/generate-testdata.mjs",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0 <12"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "iconv-lite": "^0.7.3",
    "papaparse": "^5.5.4",
    "string_decoder": "^1.3.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
